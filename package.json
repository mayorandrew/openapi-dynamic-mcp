{
  "name": "openapi-dynamic-mcp",
  "version": "0.3.3",
  "description": "MCP stdio server for OpenAPI APIs",
  "mcpName": "io.github.mayorandrew/openapi-dynamic",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openapi-dynamic-mcp": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayorandrew/openapi-dynamic-mcp.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:package-metadata": "node ./scripts/check-package-metadata.mjs",
    "dev": "tsx src/cli.ts",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.js,.cjs,.mjs,.json",
    "lint:fix": "eslint . --fix --ext .ts,.js,.cjs,.mjs,.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.include='src/**/*.ts'",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "openapi",
    "stdio"
  ],
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cmd-ts": "^0.15.0",
    "oauth4webapi": "^3.8.5",
    "openapi-types": "^12.1.3",
    "swagger2openapi": "^7.0.8",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-json-schema-validator": "^6.2.0",
    "eslint-plugin-jsonc": "^3.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^16.3.2",
    "nock": "^14.0.10",
    "prettier": "^3.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
